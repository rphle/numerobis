from si import @Length, @Mass, @Time, @Volume
from si import @metre, @kilogram, @second, @kelvin

unit inch = 0.0254 * metre
unit foot = 12 * inch
unit mile = 5280 * foot

unit pound = 0.453592 * kilogram

unit ft = foot
unit mi = mile
unit lb = pound

unit yard = 3 * foot
unit yd = yard
unit ounce = pound / 16
unit oz = ounce

unit gallon = 0.00378541 * metre^3  # US gallon (1 US gallon ≈ 0.00378541 cubic meters)
unit gal = gallon

unit fahrenheit = (5/9) * (_ kelvin + 459.67);
unit °F = fahrenheit
