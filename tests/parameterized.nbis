# ---
const dollar!(year: Int): Num = {
    history = [
        1.9176, 1.8522, 1.7912, 1.7340, 1.6804, 1.6300, 1.5826, 1.5379, 1.4957,
        1.4558, 1.4179, 1.3818, 1.3474, 1.3145, 1.2829, 1.2527, 1.2236, 1.1957,
        1.1687, 1.1427, 1.1175, 1.0931, 1.0694, 1.0464, 1.0240, 1.0021, 1.0000
    ]
    return history[year - 2000]
}

dimension Money
unit dollar[year: Int] = @dollar(year)

5 dollar[2026]
