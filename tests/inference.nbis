# ---
map!(f: ![[x: Int], Int], lst: List[Int]): List[Int] =
    if lst == [] then [] else [f(lst[0])] + map(f, lst[1:])
double!(x: Int) = x * 2
result = map(double, [1, 2, 3])

# ---
fold!(f: ![[a: Int, b: Int], Int], acc: Int, lst: List[Int]): Int =
    if lst == [] then acc else fold(f, f(acc, lst[0]), lst[1:])
add!(a: Int, b: Int) = a + b
result = fold(add, 0, [1, 2, 3, 4, 5])

# ---
compose!(f: ![[n: Int], Int], g: ![[n: Int], Int]) = !(x: Int) = f(g(x))
add_one!(n: Int) = n + 1
double!(n: Int) = n * 2
combined = compose(double, add_one)
result = combined(5)

# ---
apply!(f: ![[n: Int], Int], x: Int) = f(x)
increment!(n: Int) = n + 1
result = apply(increment, 10)

# ---
twice!(f: ![[n: Int], Int], x: Int) = f(f(x))
add_five!(n: Int) = n + 5
result = twice(add_five, 10)

# ---
chain!(f: ![[n: Int], Int], g: ![[n: Int], Int], h: ![[n: Int], Int]) = !(x: Int) = f(g(h(x)))
a!(n: Int) = n + 1
b!(n: Int) = n * 2
c!(n: Int) = n - 3
combined = chain(a, b, c)
result = combined(10)

