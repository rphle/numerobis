# ---
struct Fruit {
    name: Str,
    size: Length,
    edible: Bool = false
}

apple = Fruit("Apple", 10cm, true)
ananas = Fruit("Ananas", 30cm)

echo(apple)
echo(ananas)
echo(apple.name)
echo(apple.size -> m)
apple.size = 2m
echo(apple.size+10cm)
