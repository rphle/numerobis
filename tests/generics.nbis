from si import @(metre, kilogram, second, Mass, Length, Time)

# ---
identity!(x: Any) = x
identity(5)

# ---
identity!(x: Any) = x
identity("hello")

# ---
identity!(x: Int[Any]) = x
identity(5 kilogram)

# ---
identity!(x: List[Any]) = x
identity([1, 2, 3])

# ---
identity!(x: Any) = x
a = identity(5)
b = identity("test")
c = identity(10 kilogram)

# ---
double!(x: Int) = x * 2
double(5)

# ---
double!(x: Num) = x * 2
double(10.5)

# ---
double!(x: Num?) = x * 2
double(5 kilogram)

# E513
double!(x: Num[Any]) = x * 2
double([1, 2, 3])

# ---
add!(a: Int, b: Int) = a + b
add(5, 10)

# ---
add!(a: Str, b: Str) = a + b
add("hello", "world")

# ---
add!(a: Mass, b: Mass) = a + b
add(5 kilogram, 10 kilogram)

# ---
add!(a: List[Any], b: List[Int]) = a + b
add([1, 2], [3, 4])

# ---
poly!(x: Int?) = x * x
area = poly(5 metre)

# ---
poly!(x: Num?) = x * x
int_squared = poly(3)

# ---
poly!(x: Int?) = x * x
mass_squared = poly(10 kilogram)

# ---
first!(lst: List) = lst[0]
first([1, 2, 3])

# ---
first!(lst: List[Str]) = lst[0]
first(["a", "b", "c"])

# ---
first!(lst: List[Mass]) = lst[0]
first([1 kilogram, 2 kilogram])

# ---
length!(lst: List[Int]): Int = if lst == [] then 0 else 1 + length(lst[1:])
length([1, 2, 3, 4, 5])

# ---
length!(lst: List[Str]): Int = if lst == [] then 0 else 1 + length(lst[1:])
length(["a", "b", "c"])

# ---
length!(lst: List[Mass]): Int = if lst == [] then 0 else 1 + length(lst[1:])
length([1 kilogram, 2 kilogram, 3 kilogram])

# ---
map!(f: ![[x: Int], Int], lst: List[Int]): List[Int] = if lst == [] then [] else [f(lst[0])] + map(f, lst[1:])
double!(x: Int) = x * 2
map(double, [1, 2, 3])

# ---
map!(f: ![[x: Mass], Mass], lst: List[Mass]): List[Mass] = if lst == [] then [] else [f(lst[0])] + map(f, lst[1:])
add_unit!(x: Mass) = x + (1 kilogram)
map(add_unit, [1 kilogram, 2 kilogram, 3 kilogram])

# ---
compose!(f: ![[n: Int], Int], g: ![[n: Int], Int], x: Int) = f(g(x))
add_one!(n: Int) = n + 1
double!(n: Int) = n * 2
compose(double, add_one, 5)

# ---
apply_twice!(f: ![[n: Int], Int], x: Int) = f(f(x))
increment!(n: Int) = n + 1
apply_twice(increment, 10)

# ---
make_adder!(n: Int) = !(x: Int) = x + n
add_five = make_adder(5)
add_five(10)

# ---
make_adder!(n: Mass) = !(x: Mass) = x + n
add_mass = make_adder(5 kilogram)
add_mass(10 kilogram)

# ---
curry!(f: ![[x: Int, y: Int], Int], a: Int) = !(b: Int) = f(a, b)
add!(x: Int, y: Int) = x + y
add_five = curry(add, 5)
add_five(10)

# ---
const!(x: Int, y: Int) = x
const(5, 10)

# ---
const!(x: Str, y: Int) = x
const("hello", 100)

# ---
const!(x: Int[Any], y: Int?) = x
const(5 kilogram, 10 metre)

either!(flag: Bool, a: Any, b: Any) = if flag then a else b

either(true, 5, 10)
either(false, "yes", "no")
either(true, 5 kilogram, 10 kilogram)

# ---
empty_to_default!(lst: List[Any], default: Num?) = if lst == [] then [default] else lst

empty_to_default([], 5)
empty_to_default([1, 2], 10)
empty_to_default([], 5 kilogram)

# ---
chain!(f: ![[n: Int], Int], g: ![[n: Int], Int], h: ![[n: Int], Int], x: Int) = h(g(f(x)))
a!(n: Int) = n + 1
b!(n: Int) = n * 2
c!(n: Int) = n - 3
chain(a, b, c, 5)

# ---
flip!(f: ![[x: Any, y: Any], Any], a: Any, b: Any) = f(b, a)
subtract!(x: Int, y: Int) = x - y
flip(subtract, 3, 10)

# ---
repeat!(f: ![[x: Int], Int], n: Int, x: Int): Int = if n <= 0 then x else repeat(f, n - 1, f(x))
double!(x: Int) = x * 2
repeat(double, 3, 5)

# E703
mixed!(x: Length) = x + 5 kilogram
mixed(10 metre)

# E703
incompatible!(a: Mass, b: Length) = a + b
incompatible(5 kilogram, 10 metre)

# E703
conflicted!(x: Mass) = {
    y = x + 5 kilogram
    z = x + 10 metre
}
conflicted(42)

# E521
branch_mismatch!(flag: Bool, x: Int?) = if flag then x else x * 2 kilogram
branch_mismatch(true, 5)

# E521
inconsistent!(x: Num) = if x == 0 then 5 kilogram else 10 metre
inconsistent(0)
