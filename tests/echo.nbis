# ---
greet!(name: Str, greeting: Str = "Hello", punct: Str = "!"): Str = greeting + " " + name + punct
echo(greet("World", punct="."))

# ---
factorial!(n: Int): Int = if n <= 1 then 1 else n * factorial(n - 1)
echo(factorial(5))

# ---
fib!(n: Int): Int = if n <= 1 then n else fib(n - 1) + fib(n - 2)
echo(fib(10))

# ---
sum_list!(lst: List[Int]): Int = if lst == [] then 0 else lst[0] + sum_list(lst[1:])
echo(sum_list([1, 2, 3, 4, 5]))

# ---
f!(x: Int) = x * 2
g!(y: Int) = y + 3
h!(z: Int) = g(f(z))
echo(h(5))

# ---
return_early!(x: Int): Int = {
    if x < 0 then return 0
    return x * 2
}
echo(return_early(5))
echo(return_early(-5))

# ---
curry!(f: ![[x: Int, y: Int], Int], a: Int) = !(b: Int) = f(a, b)
add!(x: Int, y: Int) = x + y
add_five = curry(add, 5)
echo(add_five(10))

# ---
x = 10
outer!(greeting: Str) = {
    y = 20
    inner!() = {
        echo(greeting)
        return x + y
    }
    echo(inner())
}
x = 20
outer("Hello")

# ---
map_func!(f: ![[value: Num], Num], lst: List[Num]): List[Num] = {
    r = []
    for item in lst do {
        r = r + [f(item)]
    }
    return r
}

double!(value: Num) = value * 2
mapped = map_func(double, [1, 2, 3])

echo(mapped)
echo(map_func(math.floor, [1.2, 2.7, 3.4]))

echo_emoji!(value: Num) = echo(value, end=" " + [":)", ":D", ":(", ":|"][math.floor(random.random()*4)] + " ")
map_func(echo_emoji, [1.2, 2.7, 3.4])

echo("")
greet!(name: Str, greeting: Str = "Hello") = {echo(greeting + ", " + name + "!")}
greet("Alice")

# ---
i = 0
while true do {
    i = i + 1
    if i >= 11 then {break}
    if i % 2 == 0 then {continue}
    echo(i)
}

# ---
sieve!(limit: Int): List[Int] = {
    is_prime: List[Bool] = [true] * (limit + 1)
    is_prime[0] = false
    is_prime[1] = false

    max_check = (limit ^ 0.5) -> Int

    for i in 2..max_check do {
        if is_prime[i] then {
            for j in (i * i)..limit..i do {
                is_prime[j] = false
            }
        }
    }

    primes: List[Int] = []
    for i in 2..limit do {
        if is_prime[i] == true then {
            primes = primes + [i]
        }
    }
    return primes
}

primes = sieve(100)
echo("Primes ≤ 100: " + (primes -> Str))

