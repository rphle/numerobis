from si import @(W, J, g, kg, Mass, Volume)
# ---
echo(42)

# ---
dimension Length
dimension Time

unit m: Length
unit cm: Length = 0.01 m
unit km: Length = 1000 m
unit ft = 0.3m
unit mile = 1600 m

unit s: Time
unit h: Time = 3600 s

echo(42)            # 42
echo(5(2*km))       # 5 2*km
echo(1 m^(2*1))     # 1 m^2
echo(2(1000*m))     # 2 1000*m
echo(2(100*2^2*m))  # 2 400*m
echo(3m^3)          # 3 m^3
echo(100 km/h + 0.05km/s) # 280 km/h
echo(5m*s)          # 5 m*s

echo(2km + 500m)    # 2.5 km
echo(10000ft -> m)  # 3000 m
echo(55 mile/h -> m/s) # 24.4444 m/s

echo(3 ((m/s)^2))   # 3 m^2/s^2
echo(4 (m/(-s)))    # 4 -1*m/s
echo(5(2*km) / 1 km)

x: Mass/Length^3 = 1 (kg/m^3)

# ---
dimension Time;
unit sec: Time;
unit min = 60 * sec;
unit hour = 60 * min;
unit day = 24 * hour;
unit week = 7 * day;
unit month = 30 * day;
unit year = 365 * day;

age = 17.5 year + 1 month + 2 week + 15 hour + 48 min;
echo(age)
echo(age -> year)
echo(age -> week)

# ---
unit a;

x = 5 (2*a) / 1a
y = x -> 1
x1 = x + 3
y1 = y + 3

echo(x) # 5 2
echo(y) # 10
echo(x1) # 6.5 2
echo(y1) # 13

# ---
echo(42 kg -> 1) # 42

# ---
unit kt = 0.2g
echo(8kt -> kg)

# ---
from si import @(m, cm)
unit L: Volume = (0.1m)^3
unit mL: Volume = 0.001 L

echo(1mL == 1 cm^3)

# ---
unit mW = 0.001 W
unit dBm = 10^(_ mW / 10mW)

echo(2 * 60dBm)
echo(23W)
echo(60dBm |+| 60dBm)

# ---
dimension Temperature
unit K: Temperature
unit C: Temperature = _ K + 273.15;
unit F = (5/9) * (_ K + 459.67);

echo(5C)
echo(0C -> K)
echo(0C -> F)
echo(0C + 32F) # 0C + 0C
echo(0C |+| 32F)

# E543
from si import @K
unit t = 5 W + 3 W + 2 K

# ---
dimension Length
unit m: Length;
unit km = 1000m
unit km1 = 1000*m
unit L: Volume = (0.1m)^3;
unit L1: Volume = (0.1*m)^3;
unit L2: Volume = 0.001 * (m^3);
unit L3: Volume = 0.001(m^3);

F = 6000.0 kg
D = 0.81 kg/L
D2 = 0.81 kg/L2

echo(5 L)
echo(5 L1)
echo(5 L2)
echo(5 L3)

echo(5 km)
echo(5 km1)

echo(F / D)
echo(F / D2)
