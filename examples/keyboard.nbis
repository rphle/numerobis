from graphics import *

init(600, 600)

while not quit_requested() do {
    rect(0,0,600,600)
    if key_pressed("Left") then
        rect(0,0,200,600, "#f00")
    if key_pressed("Down") then
        rect(200,0,200,600, "#0f0")
    if key_pressed("Right") then
        rect(400,0,200,600, "#00f")
    blit()
}
