{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Numerobis",
  "scopeName": "source.nbis",
  "fileTypes": [
    "nbis"
  ],
  "patterns": [
    {
      "include": "#block-comment"
    },
    {
      "include": "#line-comment"
    },
    {
      "include": "#import-statement"
    },
    {
      "include": "#dimension-definition"
    },
    {
      "include": "#unit-definition"
    },
    {
      "include": "#struct-definition"
    },
    {
      "include": "#function-declaration"
    },
    {
      "include": "#anonymous-function"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#type-annotation"
    },
    {
      "include": "#conversion-operator"
    },
    {
      "include": "#string"
    },
    {
      "include": "#number-with-unit"
    },
    {
      "include": "#number"
    },
    {
      "include": "#boolean"
    },
    {
      "include": "#unit-reference"
    },
    {
      "include": "#constant-reference"
    },
    {
      "include": "#builtin-types"
    },
    {
      "include": "#function-call"
    },
    {
      "include": "#module-access"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifier"
    }
  ],
  "repository": {
    "block-comment": {
      "name": "comment.block.nbis",
      "begin": "#\\[",
      "end": "\\]#",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.comment.begin.nbis"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.comment.end.nbis"
        }
      }
    },
    "line-comment": {
      "name": "comment.line.number-sign.nbis",
      "match": "#.*$",
      "captures": {
        "0": {
          "name": "comment.line.number-sign.nbis"
        }
      }
    },
    "import-statement": {
      "patterns": [
        {
          "comment": "from X import Y, Z as W",
          "name": "meta.import.from.nbis",
          "match": "\\b(from)\\s+([a-zA-Z_][\\w°]*)\\s+(import)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.import.nbis"
            },
            "2": {
              "name": "entity.name.module.nbis"
            },
            "3": {
              "name": "keyword.control.import.nbis"
            }
          }
        },
        {
          "comment": "import X as Y",
          "name": "meta.import.nbis",
          "match": "\\b(import)\\s+([a-zA-Z_][\\w°]*)",
          "captures": {
            "1": {
              "name": "keyword.control.import.nbis"
            },
            "2": {
              "name": "entity.name.module.nbis"
            }
          }
        },
        {
          "comment": "as alias in import",
          "match": "\\b(as)\\s+([a-zA-Z_][\\w°]*)",
          "captures": {
            "1": {
              "name": "keyword.control.as.nbis"
            },
            "2": {
              "name": "entity.name.namespace.nbis"
            }
          }
        }
      ]
    },
    "dimension-definition": {
      "name": "meta.definition.dimension.nbis",
      "match": "\\b(dimension)\\s+([a-zA-Z_][\\w°]*)",
      "captures": {
        "1": {
          "name": "storage.type.dimension.nbis"
        },
        "2": {
          "name": "entity.name.type.dimension.nbis"
        }
      }
    },
    "unit-definition": {
      "name": "meta.definition.unit.nbis",
      "match": "\\b(unit)\\s+([a-zA-Z_][\\w°]*)",
      "captures": {
        "1": {
          "name": "storage.type.unit.nbis"
        },
        "2": {
          "name": "entity.name.type.unit.nbis"
        }
      }
    },
    "struct-definition": {
      "name": "meta.definition.struct.nbis",
      "match": "\\b(struct)\\s+([A-Z][\\w°]*)",
      "captures": {
        "1": {
          "name": "storage.type.struct.nbis"
        },
        "2": {
          "name": "entity.name.type.struct.nbis"
        }
      }
    },
    "function-declaration": {
      "comment": "Named function",
      "name": "meta.function.declaration.nbis",
      "match": "\\b([a-zA-Z_][\\w°]*)(!)",
      "captures": {
        "1": {
          "name": "entity.name.function.nbis"
        },
        "2": {
          "name": "punctuation.definition.function.nbis"
        }
      }
    },
    "anonymous-function": {
      "comment": "Anonymous function",
      "match": "(?<![\\w°])(!)(?=\\s*\\()",
      "captures": {
        "1": {
          "name": "punctuation.definition.function.anonymous.nbis"
        }
      }
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.nbis",
          "match": "\\b(if|then|else|for|in|do|while|return|break|continue)\\b"
        },
        {
          "name": "keyword.control.extern.nbis",
          "match": "\\b(extern|global|debug)\\b"
        },
        {
          "name": "keyword.operator.logical.nbis",
          "match": "\\b(or|and|not|xor)\\b"
        }
      ]
    },
    "type-annotation": {
      "patterns": [
        {
          "comment": "Function type annotation",
          "name": "meta.type.function-annotation.nbis",
          "begin": "(:)\\s*(!)(\\[)(\\[)",
          "end": "(\\])",
          "beginCaptures": {
            "1": {
              "name": "punctuation.separator.colon.nbis"
            },
            "2": {
              "name": "punctuation.definition.function-type.nbis"
            },
            "3": {
              "name": "punctuation.definition.type-params.begin.nbis"
            },
            "4": {
              "name": "punctuation.definition.type-params.begin.nbis"
            }
          },
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.type-params.end.nbis"
            }
          },
          "patterns": [
            {
              "include": "#type-inner"
            }
          ]
        },
        {
          "comment": "Type variable ?T",
          "name": "storage.type.variable.nbis",
          "match": "(\\?)([a-zA-Z_][\\w°]*)",
          "captures": {
            "1": {
              "name": "keyword.operator.type-variable.nbis"
            },
            "2": {
              "name": "storage.type.variable.name.nbis"
            }
          }
        }
      ]
    },
    "type-inner": {
      "patterns": [
        {
          "include": "#builtin-types"
        },
        {
          "include": "#struct-type-ref"
        },
        {
          "include": "#operators"
        },
        {
          "include": "#punctuation"
        },
        {
          "include": "#identifier"
        }
      ]
    },
    "struct-type-ref": {
      "comment": "Struct instance reference",
      "name": "meta.type.struct-ref.nbis",
      "match": "(\\{)([A-Z][\\w°]*)(\\})",
      "captures": {
        "1": {
          "name": "punctuation.definition.struct-type.begin.nbis"
        },
        "2": {
          "name": "entity.name.type.struct.nbis"
        },
        "3": {
          "name": "punctuation.definition.struct-type.end.nbis"
        }
      }
    },
    "conversion-operator": {
      "name": "keyword.operator.conversion.nbis",
      "match": "\\(?->"
    },
    "string": {
      "name": "string.quoted.double.nbis",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.nbis"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.nbis"
        }
      },
      "patterns": [
        {
          "name": "constant.character.escape.nbis",
          "match": "\\\\."
        }
      ]
    },
    "number-with-unit": {
      "name": "meta.number-with-unit.nbis",
      "match": "(?<![\\w°])(\\d[\\d_]*(?:\\.\\d[\\d_]*)?(?:[eE][+-]?\\d[\\d_]*(?:\\.\\d[\\d_]*)?)?)\\s+(?=[a-zA-Z°])",
      "captures": {
        "1": {
          "name": "constant.numeric.nbis"
        }
      }
    },
    "number": {
      "name": "constant.numeric.nbis",
      "match": "(?<![\\w°])\\d[\\d_]*(?:\\.\\d[\\d_]*)?(?:[eE][+-]?\\d[\\d_]*(?:\\.\\d[\\d_]*)?)?"
    },
    "boolean": {
      "name": "constant.language.boolean.nbis",
      "match": "\\b(true|false)\\b"
    },
    "unit-reference": {
      "patterns": [
        {
          "name": "meta.unit-reference.nbis",
          "match": "(@)([a-zA-Z_][\\w°]*)",
          "captures": {
            "1": {
              "name": "keyword.operator.unit-ref.nbis"
            },
            "2": {
              "name": "entity.name.type.unit.nbis"
            }
          }
        },
        {
          "name": "keyword.operator.unit-ref.nbis",
          "match": "@(?=\\()"
        }
      ]
    },
    "constant-reference": {
      "comment": "Constants that look like ALL_CAPS identifiers",
      "name": "variable.other.constant.nbis",
      "match": "\\b([A-Z][A-Z0-9_]{2,})\\b"
    },
    "builtin-types": {
      "name": "support.type.builtin.nbis",
      "match": "\\b(Int|Num|Str|Bool|List|Any)\\b"
    },
    "function-call": {
      "name": "meta.function-call.nbis",
      "match": "\\b([a-zA-Z_][\\w°]*)(?=\\s*\\()",
      "captures": {
        "1": {
          "name": "entity.name.function.call.nbis"
        }
      }
    },
    "module-access": {
      "name": "meta.module-access.nbis",
      "match": "\\b([a-zA-Z_][\\w°]*)(\\.)",
      "captures": {
        "1": {
          "name": "variable.other.object.nbis"
        },
        "2": {
          "name": "punctuation.accessor.nbis"
        }
      }
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.nbis",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.arithmetic.nbis",
          "match": "(\\|\\+\\||\\|\\-\\||\\^|\\*|//|/|%|\\+|-)"
        },
        {
          "name": "keyword.operator.assignment.nbis",
          "match": "(?<!=)(=)(?!=)"
        },
        {
          "name": "keyword.operator.range.nbis",
          "match": "\\.\\."
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.definition.block.begin.nbis",
          "match": "\\{"
        },
        {
          "name": "punctuation.definition.block.end.nbis",
          "match": "\\}"
        },
        {
          "name": "punctuation.definition.group.begin.nbis",
          "match": "\\("
        },
        {
          "name": "punctuation.definition.group.end.nbis",
          "match": "\\)"
        },
        {
          "name": "punctuation.definition.bracket.begin.nbis",
          "match": "\\["
        },
        {
          "name": "punctuation.definition.bracket.end.nbis",
          "match": "\\]"
        },
        {
          "name": "punctuation.separator.comma.nbis",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.nbis",
          "match": ":"
        },
        {
          "name": "punctuation.terminator.statement.nbis",
          "match": ";"
        },
        {
          "name": "punctuation.accessor.dot.nbis",
          "match": "\\."
        }
      ]
    },
    "identifier": {
      "name": "variable.other.nbis",
      "match": "(?:[^\\W\\d]|°)[\\w°]*"
    }
  }
}
